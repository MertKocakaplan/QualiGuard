# QualiGuard — ignore patterns. Repo yalniz kaynak kod icerir;
# veri toplama + model egitimi klonlayan tarafindan sifirdan calistirilir.

# Runtime ciktilari / veri (collect + train uretimi)
output/
repos/
*.log
*.parquet
*.csv.gz

# Model artifactlari + config/manifest (egitim ile yeniden uretilir)
models/

# Dokumanlar / ic planlama (kaynak kod disi) — repoya girmez
docs/
*.docx
*.rar
PLAN.md
CHANGELOG.md

# Makale figur yardimcilari (araç kaynağı değil; hardcoded yollar iceriyor)
scripts/make_fig1_architecture.py
scripts/make_paper_figs.py

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Sanal ortamlar
venv/
.venv/
env/

# VS Code (lokal editor ayarlari)
.vscode/

# Sirlar
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Claude Code harness state (per-machine)
.claude/

# Graphify (yalniz gelistirme kolayligi — repoya girmez)
graphify-out/
.graphify_*
.graphifyignore
